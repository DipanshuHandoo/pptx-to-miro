# Miro REST API credentials
# Create an app at https://developers.miro.com, enable boards:read + boards:write,
# install it on your board, then generate an access token.
MIRO_ACCESS_TOKEN=your_token_here

# Board ID from the board URL: https://miro.com/app/board/{MIRO_BOARD_ID}/
MIRO_BOARD_ID=your_board_id_here

# Optional: override the Python executable used to run the parser.
# Defaults to "python" on Windows and "python3" elsewhere.
# PYTHON_BIN=python
